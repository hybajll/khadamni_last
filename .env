# Khadamni (optional): YouTube/Vimeo embed URL for the motivational video on /user/home
# Example: MOTIVATIONAL_VIDEO_EMBED_URL="https://www.youtube.com/embed/VIDEO_ID"
MOTIVATIONAL_VIDEO_EMBED_URL=

# Khadamni (optional): local MP4 path under /public (recommended for local dev)
# Example: public/videos/khadamni-intro.mp4 -> MOTIVATIONAL_VIDEO_PATH=videos/khadamni-intro.mp4
MOTIVATIONAL_VIDEO_PATH=videos/khadamni-intro.mp4

###> openai ###
# Set this in .env.local (recommended): OPENAI_API_KEY=sk-...
OPENAI_API_KEY=
# Default model for CV improvement (can be overridden in .env.local)
OPENAI_MODEL=gpt-4.1-mini
###< openai ###

###> ai_provider ###
# Choose which API provider to use for CV improvement:
# - openrouter (recommended free tier)
# - openai
AI_PROVIDER=openrouter

# OpenRouter (free models router: openrouter/free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
