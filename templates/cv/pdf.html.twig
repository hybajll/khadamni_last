<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>CV</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 12px;
            color: #0f172a;
            line-height: 1.35;
            margin: 0;
            padding: 0;
        }
        .sheet-header {
            padding: 18px 18px 12px 18px;
            border-bottom: 2px solid #ff8c00;
            background: #ffffff;
        }
        .name {
            font-size: 20px;
            font-weight: 800;
            margin: 0;
            color: #0a2340;
        }
        .meta {
            margin-top: 6px;
            color: #334155;
            font-size: 11px;
        }
        .meta span { margin-right: 10px; }
        .title {
            margin-top: 8px;
            font-weight: 700;
            color: #0f172a;
        }
        .sheet-body {
            padding: 14px 18px 18px 18px;
        }

        .grid {
            width: 100%;
            border-collapse: collapse;
        }
        .col-left {
            width: 32%;
            vertical-align: top;
            padding-right: 14px;
            border-right: 1px solid #e5e7eb;
        }
        .col-right {
            width: 68%;
            vertical-align: top;
            padding-left: 14px;
        }

        .section { margin-bottom: 14px; }
        .section-title {
            margin: 0 0 6px 0;
            font-size: 11px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #0a2340;
            font-weight: 800;
        }

        ul {
            margin: 0;
            padding-left: 16px;
        }
        li { margin: 0 0 4px 0; }
        .footer {
            position: fixed;
            bottom: 10px;
            left: 18px;
            right: 18px;
            font-size: 10px;
            color: #64748b;
            text-align: right;
        }
    </style>
</head>
<body>
<div class="sheet-header">
    <p class="name">
        {% if user and (user.prenom or user.nom) %}
            {{ (user.prenom ?: '') ~ ' ' ~ (user.nom ?: '') }}
        {% else %}
            {{ user.email }}
        {% endif %}
    </p>
    <div class="meta">
        <span>Email: {{ user.email }}</span>
        <span>Généré: {{ generated_at|date('d/m/Y') }}</span>
    </div>
    <div class="title">{{ cv.titre }}</div>
</div>

<div class="sheet-body">
    {% if layout is defined and (layout.left|length > 0 or layout.right|length > 0) %}
        <table class="grid">
            <tr>
                <td class="col-left">
                    {% for section in layout.left %}
                        <div class="section">
                            <div class="section-title">{{ section.title }}</div>
                            <ul>
                                {% for item in section.items %}
                                    <li>{{ item }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endfor %}
                </td>
                <td class="col-right">
                    {% for section in layout.right %}
                        <div class="section">
                            <div class="section-title">{{ section.title }}</div>
                            <ul>
                                {% for item in section.items %}
                                    <li>{{ item }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endfor %}
                </td>
            </tr>
        </table>
    {% else %}
        <div class="section">
            <div class="section-title">CV</div>
            <div style="white-space: pre-wrap;">{{ (cv.contenuAmeliore ?: cv.contenuOriginal) }}</div>
        </div>
    {% endif %}
</div>

<div class="footer">Khadamni — خدمني</div>
</body>
</html>
