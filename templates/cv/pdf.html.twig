<!doctype html>
<html lang="fr" {% if is_rtl %}dir="rtl"{% endif %}>
<head>
    <meta charset="UTF-8">
    <title>CV</title>
    <style>
        @page { margin: 18px; }
        * { box-sizing: border-box; }
        body {
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 12px;
            color: #0f172a;
            line-height: 1.35;
            margin: 0;
            padding: 0;
        }

        .rtl { direction: rtl; text-align: right; }

        .sheet-header { margin-bottom: 10px; }
        .header-table { width: 100%; border-collapse: collapse; }
        .header-left { width: 70%; vertical-align: top; }
        .header-right { width: 30%; vertical-align: top; text-align: right; }
        .rtl .header-right { text-align: left; }

        .header-photo {
            width: 96px;
            height: 96px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid #e5e7eb;
        }
        .name { font-size: 20px; font-weight: 800; margin: 0; color: #0a2340; }
        .meta { margin-top: 6px; color: #334155; font-size: 11px; }
        .meta span { margin-right: 10px; }
        .rtl .meta span { margin-right: 0; margin-left: 10px; }
        .title { margin-top: 8px; font-weight: 700; color: #0f172a; }
        .separator { border-bottom: 2px solid #ff8c00; margin-top: 10px; }

        .grid { width: 100%; border-collapse: collapse; }
        .col-left { width: 32%; vertical-align: top; padding-right: 12px; border-right: 1px solid #e5e7eb; }
        .col-right { width: 68%; vertical-align: top; padding-left: 12px; }
        .rtl .col-left { border-right: 0; border-left: 1px solid #e5e7eb; padding-right: 0; padding-left: 12px; }
        .rtl .col-right { padding-left: 0; padding-right: 12px; }

        /* Dompdf can push the whole content to the next page when too many blocks use "avoid". */
        .section { margin-bottom: 14px; page-break-inside: auto; }
        .section-title {
            margin: 0 0 6px 0;
            font-size: 11px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #0a2340;
            font-weight: 800;
        }
        ul { margin: 0; padding-left: 16px; }
        .rtl ul { padding-left: 0; padding-right: 16px; }
        li { margin: 0 0 4px 0; }
    </style>
</head>
<body class="{% if is_rtl %}rtl{% endif %}">

<div class="sheet-header">
    <table class="header-table">
        <tr>
            <td class="header-left">
                <p class="name">
                    {% if user and (user.prenom or user.nom) %}
                        {{ (user.prenom ?: '') ~ ' ' ~ (user.nom ?: '') }}
                    {% else %}
                        {{ user.email }}
                    {% endif %}
                </p>
                <div class="meta">
                    <span>Email: {{ user.email }}</span>
                    <span>Généré: {{ generated_at|date('d/m/Y') }}</span>
                </div>
                <div class="title">{{ cv.titre }}</div>
            </td>
            <td class="header-right">
                {% if photo_data_uri %}
                    <img class="header-photo" src="{{ photo_data_uri }}" alt="Photo">
                {% endif %}
            </td>
        </tr>
    </table>
    <div class="separator"></div>
</div>

{# Layout rendering can fail when parsing returns empty/low-signal sections. #}
{% set has_layout = layout is defined and (layout.left|length > 0 or layout.right|length > 0) %}
{% set has_items = false %}
{% if has_layout %}
    {% for section in layout.left %}
        {% if section.items is defined and section.items|length > 0 %}{% set has_items = true %}{% endif %}
    {% endfor %}
    {% for section in layout.right %}
        {% if section.items is defined and section.items|length > 0 %}{% set has_items = true %}{% endif %}
    {% endfor %}
{% endif %}

{% if has_layout and has_items %}
    <table class="grid">
        <tr>
            <td class="col-left">
                {% for section in layout.left %}
                    <div class="section">
                        <div class="section-title">{{ section.title }}</div>
                        <ul>
                            {% for item in section.items %}
                                <li>{{ item }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endfor %}
            </td>
            <td class="col-right">
                {% for section in layout.right %}
                    <div class="section">
                        <div class="section-title">{{ section.title }}</div>
                        <ul>
                            {% for item in section.items %}
                                <li>{{ item }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endfor %}
            </td>
        </tr>
    </table>
{% else %}
    <div class="section">
        <div class="section-title">CV</div>
        <div style="white-space: pre-wrap;">{{ cv.contenuOriginal }}</div>
    </div>
{% endif %}

<div style="margin-top: 10px; font-size: 10px; color: #64748b; text-align: right;">Khadamni — خدمني</div>

</body>
</html>
