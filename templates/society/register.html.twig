{% extends 'base.html.twig' %}

{% block title %}Inscription Société{% endblock %}

{% block body %}
<div class="hero-auth d-flex align-items-center justify-content-center bg-cream">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h3 class="text-darken fw-bold">Inscription Société</h3>
                            <p class="text-muted">Créez votre compte entreprise et commencez à publier des offres.</p>
                        </div>

                        {{ form_start(form) }}
                            {{ form_errors(form) }}

                            <div class="row mb-3">
                                <div class="col-md-12">
                                    {{ form_row(form.name, {attr: {class: 'form-control', placeholder: 'Nom de votre entreprise'}}) }}
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-12">
                                    {{ form_row(form.email, {attr: {class: 'form-control', placeholder: 'Email professionnel'}}) }}
                                </div>
                            </div>

                            <div class="row mb-3 g-3">
                                <div class="col-md-6">
                                    {{ form_row(form.password.first, {attr: {class: 'form-control', placeholder: 'Mot de passe (min 4 caractères)'}}) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.password.second, {attr: {class: 'form-control', placeholder: 'Confirmer le mot de passe'}}) }}
                                </div>
                            </div>

                            <div class="row mb-3 g-3">
                                <div class="col-md-6">
                                    {{ form_row(form.phone, {attr: {class: 'form-control', placeholder: '+216 XX XXX XXX'}}) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.domain, {attr: {class: 'form-control', placeholder: 'ex: Technologie'}}) }}
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-12">
                                    {{ form_row(form.address, {attr: {class: 'form-control', placeholder: 'Adresse du siège social'}}) }}
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-12">
                                    {{ form_row(form.website, {attr: {class: 'form-control', placeholder: 'https://www.example.com'}}) }}
                                </div>
                            </div>

                            <div class="mb-3">
                                {{ form_row(form.description, {attr: {class: 'form-control', placeholder: 'Décrivez votre entreprise', rows: 4}}) }}
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary btn-lg">S'inscrire</button>
                            </div>
                        {{ form_end(form) }}

                        <div class="text-center">
                            <p class="mb-0">Vous avez déjà un compte ? <a href="{{ path('society_login') }}" class="text-orange">Se connecter</a></p>
                        </div>

                        <hr class="my-4">

                        <div class="text-center">
                            <p class="mb-0"><a href="{{ path('society_index') }}" class="text-darken">← Retour à l'accueil</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

