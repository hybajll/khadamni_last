{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe - {{ society.name }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header border-0 bg-white rounded-top-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="text-darken fw-bold mb-0">Changer le mot de passe</h3>
                        <a href="{{ path('society_profile') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Retour
                        </a>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="alert alert-light border mb-4">
                        Pour des raisons de sécurité, les informations de l'entreprise (nom/email/téléphone…) ne sont pas modifiables ici.
                    </div>

                    {{ form_start(form) }}
                        {{ form_errors(form) }}

                        <div class="mb-3">
                            {{ form_row(form.currentPassword, {attr: {class: 'form-control', placeholder: 'Mot de passe actuel'}}) }}
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_row(form.newPassword.first, {attr: {class: 'form-control', placeholder: 'Nouveau mot de passe'}}) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.newPassword.second, {attr: {class: 'form-control', placeholder: 'Confirmer le mot de passe'}}) }}
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Mettre à jour
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

