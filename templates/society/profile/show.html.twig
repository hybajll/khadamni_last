{% extends 'base.html.twig' %}

{% block title %}Profil - {{ society.name }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header border-0 bg-white rounded-top-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="text-darken fw-bold mb-0">Profil de l'entreprise</h3>
                        <a href="{{ path('society_profile_edit') }}" class="btn btn-outline-primary">
                            <i class="fas fa-edit me-2"></i> Modifier
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="text-muted mb-1">Nom de l'entreprise</p>
                            <h5 class="text-darken fw-bold">{{ society.name }}</h5>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1">Email</p>
                            <h5 class="text-darken fw-bold">{{ society.email }}</h5>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="text-muted mb-1">Telephone</p>
                            <h5 class="text-darken fw-bold">{{ society.phone or '-' }}</h5>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1">Domaine d'activite</p>
                            <h5 class="text-darken fw-bold">{{ society.domain or '-' }}</h5>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <p class="text-muted mb-1">Adresse</p>
                            <h5 class="text-darken fw-bold">{{ society.address or '-' }}</h5>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <p class="text-muted mb-1">Site web</p>
                            {% if society.website %}
                            <h5 class="text-darken fw-bold">
                                <a href="{{ society.website }}" target="_blank" class="text-orange">{{ society.website }}</a>
                            </h5>
                            {% else %}
                            <h5 class="text-darken fw-bold">-</h5>
                            {% endif %}
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <p class="text-muted mb-1">Description</p>
                            <p class="text-darken">{{ society.description or '-' }}</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <p class="text-muted mb-1">Statut</p>
                            <span class="badge {% if society.isActive %}bg-success{% else %}bg-danger{% endif %}">
                                {{ society.isActive ? 'Active' : 'Inactive' }}
                            </span>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1">Membre depuis</p>
                            <h5 class="text-darken fw-bold">{{ society.createdAt|date('d M Y') }}</h5>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mb-4">
                <a href="{{ path('society_dashboard') }}" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i> Retour au tableau de bord
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
