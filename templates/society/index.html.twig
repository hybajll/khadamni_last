{% extends 'base.html.twig' %}

{% block title %}Espace Societe - Khadamni{% endblock %}

{% block body %}
<div class="bg-cream">
    <!-- Hero Section -->
    <div class="hero-section bg-dark py-5" style="background: linear-gradient(135deg, var(--kh-navy) 0%, #102f52 100%); color: white;">
        <div class="container py-5">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h1 class="display-4 fw-bold mb-3">Publiez vos offres d'emploi</h1>
                    <p class="lead mb-4">Trouvez les meilleurs talents pour votre entreprise. Publiez des offres, gerez les candidatures et bien plus encore.</p>
                    <div class="btn-group gap-2">
                        <a href="{{ path('society_register') }}" class="btn btn-primary btn-lg">
                            <i class="fas fa-user-plus me-2"></i> S'inscrire
                        </a>
                        <a href="{{ path('society_login') }}" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-sign-in-alt me-2"></i> Se connecter
                        </a>
                    </div>
                </div>
                <div class="col-md-6 text-center">
                    <div class="feature-icon">
                        <i class="fas fa-briefcase" style="font-size: 150px; color: var(--kh-orange); opacity: 0.8;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="container py-5">
        <h2 class="text-darken fw-bold mb-5 text-center">Pourquoi choisir Khadamni ?</h2>
        
        <div class="row mb-5">
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body text-center">
                        <div style="font-size: 50px; color: var(--kh-orange); margin-bottom: 1rem;">
                            <i class="fas fa-rocket"></i>
                        </div>
                        <h5 class="card-title fw-bold">Rapide et facile</h5>
                        <p class="text-muted">Publiez vos offres en quelques minutes. Interface simple et intuitive.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body text-center">
                        <div style="font-size: 50px; color: var(--kh-orange); margin-bottom: 1rem;">
                            <i class="fas fa-users"></i>
                        </div>
                        <h5 class="card-title fw-bold">Acces a des talents</h5>
                        <p class="text-muted">Connectez-vous avec des candidats qualifies en Tunisie et dans la region.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body text-center">
                        <div style="font-size: 50px; color: var(--kh-orange); margin-bottom: 1rem;">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h5 class="card-title fw-bold">Suivi complet</h5>
                        <p class="text-muted">Tableau de bord detaille pour suivre vos offres et vos candidatures.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Offers Section -->
    {% if offers %}
    <div class="bg-white py-5">
        <div class="container">
            <h2 class="text-darken fw-bold mb-5 text-center">Dernieres offres d'emploi</h2>
            
            <div class="row">
                {% for offer in offers %}
                <div class="col-md-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm rounded-3">
                        <div class="card-body">
                            <h5 class="card-title text-darken fw-bold">{{ offer.title }}</h5>
                            <p class="text-muted mb-2">
                                <i class="fas fa-building me-2"></i> 
                                <strong>{{ offer.society.name }}</strong>
                            </p>
                            <p class="text-muted mb-3">
                                <i class="fas fa-map-marker-alt me-2"></i> {{ offer.location or 'Non specifiee' }}
                            </p>
                            <div class="mb-3">
                                <span class="badge bg-light text-dark">{{ offer.contractType }}</span>
                                {% if offer.experienceLevel %}
                                <span class="badge bg-light text-dark">{{ offer.experienceLevel }}</span>
                                {% endif %}
                            </div>
                            <p class="text-muted text-truncate mb-3">{{ offer.description[:80] }}...</p>
                            <div class="d-flex justify-content-between align-items-center">
                                {% if offer.salary %}
                                <span class="text-orange fw-bold">{{ offer.salary }} TND</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    <!-- CTA Section -->
    <div class="bg-gradient py-5" style="background: linear-gradient(135deg, var(--kh-navy) 0%, #102f52 100%); color: white;">
        <div class="container text-center">
            <h2 class="fw-bold mb-3">Pret a recruter ?</h2>
            <p class="lead mb-4">Creez votre compte maintenant et commencez a publier des offres d'emploi.</p>
            <a href="{{ path('society_register') }}" class="btn btn-primary btn-lg">
                <i class="fas fa-arrow-right me-2"></i> Creer un compte
            </a>
        </div>
    </div>
</div>
{% endblock %}
