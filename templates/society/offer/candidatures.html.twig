{% extends 'base.html.twig' %}

{% block title %}Candidatures - {{ offer.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Candidatures</h1>
            <div class="text-muted small">
                Offre: <span class="fw-semibold">{{ offer.title }}</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" href="{{ path('society_offer_show', {id: offer.id}) }}">Retour à l’offre</a>
            <a class="btn btn-primary" href="{{ path('society_offers_feed', {scope: 'mine'}) }}">Mes offres</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted">Mots-clés détectés (offre):</span>
                {% for k in offerKeywords %}
                    <span class="badge text-bg-light border">{{ k }}</span>
                {% else %}
                    <span class="text-muted">Aucun</span>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 rounded-top-4 d-flex justify-content-between align-items-center">
            <div class="fw-semibold">{{ rows|length }} candidat(s)</div>
            <div class="text-muted small">Tri: score recommandation → mots-clés</div>
        </div>
        <div class="card-body">
            {% if rows is empty %}
                <div class="alert alert-info mb-0">Aucune candidature pour cette offre pour le moment.</div>
            {% else %}
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr class="text-muted small">
                                <th>Email candidat</th>
                                <th>Score</th>
                                <th>Mots-clés trouvés</th>
                                <th class="text-end">CV</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for row in rows %}
                            {% set c = row.candidature %}
                            <tr>
                                <td class="fw-semibold">{{ c.email }}</td>
                                <td>
                                    <div class="small text-muted">Recommandation: {{ (row.recommendationScore * 100)|round }}%</div>
                                    <div class="small text-muted">Mots-clés: {{ (row.keywordScore * 100)|round }}%</div>
                                </td>
                                <td>
                                    {% if row.matchedKeywords is empty %}
                                        <span class="text-muted small">—</span>
                                    {% else %}
                                        {% for k in row.matchedKeywords %}
                                            <span class="badge text-bg-light border">{{ k }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if c.cvPath %}
                                        <a class="btn btn-sm btn-outline-primary" target="_blank" href="{{ asset('uploads/cvs/' ~ c.cvPath) }}">
                                            Télécharger
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

