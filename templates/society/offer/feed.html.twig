{% extends 'base.html.twig' %}

{% block title %}Offres - Entreprise{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="rounded-4 bg-cream shadow-sm p-4 mb-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h1 class="h4 mb-1 text-darken">Offres</h1>
                <p class="text-muted mb-0">Une vue “feed” simple, comme des publications.</p>
            </div>
            <a class="btn btn-primary" href="{{ path('society_offer_new') }}">
                <i class="fa-solid fa-plus me-2"></i>Publier une offre
            </a>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a class="btn {{ scope == 'mine' ? 'btn-primary' : 'btn-outline-primary' }}"
           href="{{ path('society_offers_feed', {scope: 'mine', q: q}) }}">
            Mes offres
        </a>
        <a class="btn {{ scope == 'all' ? 'btn-primary' : 'btn-outline-primary' }}"
           href="{{ path('society_offers_feed', {scope: 'all', q: q}) }}">
            Toutes les offres
        </a>
    </div>

    <form method="get" class="mb-4">
        <input type="hidden" name="scope" value="{{ scope }}">
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input class="form-control" name="q" value="{{ q }}" placeholder="Rechercher (titre / description)">
            <button class="btn btn-outline-primary" type="submit">Rechercher</button>
        </div>
    </form>

    <style>
        .offer-feed-item {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 1rem 2rem rgba(15, 47, 70, 0.08);
            overflow: hidden;
            border: 1px solid rgba(15, 23, 42, 0.06);
        }
        .offer-feed-stripe {
            width: 10px;
            background: var(--kh-orange);
        }
        .offer-feed-meta {
            font-size: 0.9rem;
            color: rgba(15, 23, 42, 0.70);
        }
        .offer-feed-desc {
            color: rgba(15, 23, 42, 0.85);
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .offer-badge {
            border: 1px solid rgba(15, 23, 42, 0.12);
            background: rgba(255, 255, 255, 0.8);
            color: rgba(15, 23, 42, 0.8);
            border-radius: 999px;
            padding: 4px 10px;
            font-weight: 600;
            font-size: 0.85rem;
        }
    </style>

    {% if offers is empty %}
        <div class="alert alert-light border">Aucune offre trouvée.</div>
    {% else %}
        <div class="d-grid gap-3">
            {% for offer in offers %}
                {% set isMine = offer.society and offer.society.id == society.id %}
                <div class="offer-feed-item d-flex">
                    <div class="offer-feed-stripe"></div>
                    <div class="p-4 flex-grow-1">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
                            <div class="me-3">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                    <h2 class="h5 mb-0">{{ offer.title }}</h2>
                                    {% if isMine %}
                                        <span class="offer-badge">{{ offer.isActive ? 'Active' : 'Inactive' }}</span>
                                    {% endif %}
                                </div>
                                <div class="offer-feed-meta">
                                    <span class="me-2"><i class="fa-regular fa-building me-1"></i>{{ offer.society ? offer.society.name : '—' }}</span>
                                    {% if offer.location %}<span class="me-2"><i class="fa-solid fa-location-dot me-1"></i>{{ offer.location }}</span>{% endif %}
                                    {% if offer.contractType %}<span class="me-2"><i class="fa-regular fa-file-lines me-1"></i>{{ offer.contractType }}</span>{% endif %}
                                    <span><i class="fa-regular fa-clock me-1"></i>{{ offer.createdAt ? offer.createdAt|date('d/m/Y') : '' }}</span>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                {% if isMine %}
                                    <a class="btn btn-outline-primary" href="{{ path('society_offer_show', {id: offer.id}) }}">Voir</a>
                                    <a class="btn btn-outline-primary" href="{{ path('society_offer_edit', {id: offer.id}) }}">Modifier</a>
                                {% else %}
                                    <a class="btn btn-outline-primary" href="{{ path('app_offer_public_show', {id: offer.id}) }}">Voir</a>
                                {% endif %}
                            </div>
                        </div>

                        <div class="mt-3 offer-feed-desc">{{ offer.description }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}

