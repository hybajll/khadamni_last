{% extends 'base.html.twig' %}

{% block title %}Connexion Societe{% endblock %}

{% block body %}
<div class="hero-auth d-flex align-items-center justify-content-center bg-cream">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h3 class="text-darken fw-bold">Connexion Societe</h3>
                            <p class="text-muted">Accedez a votre espace entreprise</p>
                        </div>

                        {% if error %}
                            <div class="alert alert-danger">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        <form method="post">
                            <div class="mb-3">
                                <label for="inputEmail" class="form-label">Adresse email</label>
                                <input type="email" value="{{ last_email }}" name="_username" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                            </div>
                            <div class="mb-3">
                                <label for="inputPassword" class="form-label">Mot de passe</label>
                                <input type="password" name="_password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <div class="d-grid">
                                <button class="btn btn-primary btn-lg" type="submit">Se connecter</button>
                            </div>
                        </form>

                        <div class="text-center mt-4">
                            <p class="mb-0">Pas encore de compte ? <a href="{{ path('society_register') }}" class="text-orange">S'inscrire</a></p>
                        </div>

                        <hr class="my-4">

                        <div class="text-center">
                            <p class="mb-0"><a href="{{ path('society_index') }}" class="text-darken">← Retour a l'accueil</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
