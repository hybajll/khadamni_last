{% extends 'base.html.twig' %}

{% block title %}Khadamni - Déposer une Candidature{% endblock %}

{% block body %}
<style>
    .card-custom {
        border-radius: 15px;
        overflow: hidden;
        border: none;
    }
    .header-gradient {
        background: linear-gradient(135deg, #003366 0%, #004080 100%);
        color: white;
        padding: 30px;
    }
    .form-label-custom {
        color: #003366;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .input-custom {
        border: 2px solid #e9ecef;
        border-radius: 8px;
        padding: 12px;
        transition: all 0.3s;
    }
    .input-custom:focus {
        border-color: #FF8C00;
        box-shadow: 0 0 0 0.25rem rgba(255, 140, 0, 0.1);
    }
    .btn-submit {
        background-color: #FF8C00;
        border: none;
        padding: 15px;
        font-weight: bold;
        color: white;
        border-radius: 8px;
        transition: transform 0.2s;
    }
    .btn-submit:hover {
        background-color: #e67e00;
        transform: translateY(-2px);
        color: white;
    }
</style>

<div class="row justify-content-center py-5">
    <div class="col-md-7 col-lg-6">
        <div class="card card-custom shadow-lg">
            <div class="header-gradient text-center">
                <h2 class="mb-0">REJOIGNEZ-NOUS</h2>
                <p class="opacity-75 mt-2">Complétez votre dossier en quelques secondes</p>
            </div>
            
            <div class="card-body p-4 p-lg-5 bg-white">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    
                    {# Champ Email #}
                    <div class="mb-4">
                        <label class="form-label-custom">Votre Adresse Email Professionnelle</label>
                        {{ form_widget(form.email, {'attr': {'class': 'form-control input-custom', 'placeholder': 'nom@exemple.com'}}) }}
                        <small class="text-danger">{{ form_errors(form.email) }}</small>
                    </div>

                    {# Champ CV #}
                    <div class="mb-4">
                        <label class="form-label-custom">Document CV (Format PDF)</label>
                        {{ form_widget(form.cvPath, {'attr': {'class': 'form-control input-custom'}}) }}
                        <small class="text-muted">Taille max : 2Mo</small>
                        <small class="text-danger">{{ form_errors(form.cvPath) }}</small>
                    </div>

                    {# Champ Offre #}
                    <div class="mb-5">
                        <label class="form-label-custom">Poste ou Offre Concernée</label>
                        {{ form_widget(form.offre, {'attr': {'class': 'form-select input-custom'}}) }}
                        <small class="text-danger">{{ form_errors(form.offre) }}</small>
                    </div>

                    {# Le bouton est bien à la fin #}
                    <div class="d-grid">
                        <button type="submit" class="btn btn-submit shadow">
                            SOUMETTRE MON DOSSIER MAINTENANT
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}