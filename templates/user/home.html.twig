{% extends 'base.html.twig' %}

{% block title %}Accueil - Khadamni{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body p-4">
                <h1 class="h4 mb-2 text-darken">Bienvenue{% if user and user.prenom %}, {{ user.prenom }}{% endif %}.</h1>
                <p class="text-muted mb-0">Prenez 5 minutes aujourd’hui pour améliorer votre CV et avancer vers votre prochain entretien.</p>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="fw-semibold text-darken" style="font-family: 'Cairo', sans-serif;">فيديو تعريفي</div>
                        <div class="text-muted" style="font-family: 'Cairo', sans-serif;">شاهد الفكرة بسرعة وابدأ رحلتك مع «خدمني».</div>
                    </div>
                </div>

                {% if video_path %}
                    <div class="mt-3 rounded-4 overflow-hidden border bg-dark">
                        <video class="w-100" controls preload="metadata" playsinline>
                            <source src="{{ asset(video_path) }}" type="video/mp4">
                            Votre navigateur ne supporte pas la vidéo.
                        </video>
                    </div>
                {% elseif video_embed_url %}
                    <div class="ratio ratio-16x9 mt-3 rounded-4 overflow-hidden border">
                        <iframe
                            src="{{ video_embed_url }}"
                            title="Khadamni - Intro"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            referrerpolicy="strict-origin-when-cross-origin"
                            allowfullscreen
                        ></iframe>
                    </div>
                {% else %}
                    <div class="alert alert-light border mt-3 mb-0">
                        Ajoutez une vidéo dans <code>public/videos/</code> (ex: <code>public/videos/khadamni-intro.mp4</code>).
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="mt-4">
            <div class="d-flex align-items-end justify-content-between gap-3 mb-3">
                <div>
                    <div class="text-uppercase text-muted small fw-semibold">Actualités marché</div>
                    <div class="h6 mb-0">Tendances rapides</div>
                </div>
                <span class="badge rounded-pill text-bg-light border"><i class="fa-solid fa-bolt me-2"></i>À jour</span>
            </div>

            <div class="kh-news-row" aria-label="Actualités marché">
                {% for item in news %}
                    {% set modalId = 'newsModal' ~ loop.index %}
                    <article class="kh-news-card">
                        <div class="kh-news-top">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span class="kh-news-pill"><i class="fa-solid fa-chart-line me-2"></i>Marché</span>
                                <span class="kh-news-pill light">{{ item.date|date('d/m/Y') }}</span>
                            </div>
                            <button type="button" class="btn btn-link p-0 kh-action" title="Ouvrir" data-bs-toggle="modal" data-bs-target="#{{ modalId }}">
                                <i class="fa-solid fa-up-right-from-square"></i>
                            </button>
                        </div>

                        <div class="kh-news-title">{{ item.title }}</div>
                        <div class="kh-news-summary">{{ item.summary }}</div>

                        <div class="kh-news-bottom">
                            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#{{ modalId }}">
                                Lire
                            </button>
                            <div class="flex-grow-1"></div>
                            <span class="kh-news-badge">Nouveau</span>
                        </div>
                    </article>

                    <div class="modal fade" id="{{ modalId }}" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-scrollable modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">{{ item.title }}</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="text-muted small mb-2">{{ item.date|date('d/m/Y') }}</div>
                                    <div class="text-muted" style="white-space: pre-line;">{{ item.summary }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="text-muted">Aucune actualité.</div>
                {% endfor %}
            </div>
        </div>

        <div class="mt-4">
            <h2 class="h6 text-uppercase text-muted mb-3">Guides & articles</h2>

            <div class="d-flex flex-wrap gap-2 mb-3">
                <a class="kh-chip {{ articles_lang is null ? 'active' : '' }}" href="{{ path('app_user_home') }}#articles">Tous</a>
                <a class="kh-chip {{ articles_lang == 'fr' ? 'active' : '' }}" href="{{ path('app_user_home', {lang:'fr'}) }}#articles">Français</a>
                <a class="kh-chip {{ articles_lang == 'ar' ? 'active' : '' }}" href="{{ path('app_user_home', {lang:'ar'}) }}#articles" style="font-family: 'Cairo', sans-serif;">العربية</a>
            </div>

            <div id="articles" class="vstack gap-3">
                {% set shown = 0 %}
                {% for a in articles %}
                    {% if articles_lang is null or a.lang == articles_lang %}
                        {% set shown = shown + 1 %}

                        {% set isAr = a.lang == 'ar' %}
                        {% set modalId = 'articleModal' ~ loop.index %}

                        <article class="kh-feed-card {{ isAr ? 'kh-rtl' : '' }}">
                            <header class="kh-feed-header">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="kh-feed-avatar {{ isAr ? 'ar' : 'fr' }}">
                                        {{ isAr ? 'ع' : 'FR' }}
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <div class="fw-semibold text-darken">{{ isAr ? 'خدمني' : 'Khadamni' }}</div>
                                            <span class="badge text-bg-light border">{{ isAr ? 'مقال' : 'Article' }}</span>
                                        </div>
                                        <div class="text-muted small">{{ a.date|date('d/m/Y') }}</div>
                                    </div>
                                    <div class="text-muted">
                                        <i class="fa-solid fa-ellipsis"></i>
                                    </div>
                                </div>
                            </header>

                            <div class="kh-feed-cover">
                                <div class="kh-feed-cover-inner">
                                    <div class="kh-feed-title">{{ a.title }}</div>
                                    <div class="kh-feed-summary">{{ a.summary }}</div>
                                </div>
                            </div>

                            <div class="kh-feed-actions">
                                <button type="button" class="btn btn-link p-0 kh-action" title="J'aime" onclick="return false;">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                                <button type="button" class="btn btn-link p-0 kh-action" title="Commenter" onclick="return false;">
                                    <i class="fa-regular fa-comment"></i>
                                </button>
                                <div class="flex-grow-1"></div>
                                <button type="button" class="btn btn-link p-0 kh-action" title="Enregistrer" onclick="return false;">
                                    <i class="fa-regular fa-bookmark"></i>
                                </button>
                            </div>

                            <div class="kh-feed-body">
                                <div class="kh-feed-text">
                                    {{ a.content|split('\n')|first }}
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary mt-3" data-bs-toggle="modal" data-bs-target="#{{ modalId }}">
                                    {{ isAr ? 'اقرأ أكثر' : 'Lire la suite' }}
                                </button>
                            </div>
                        </article>

                        <div class="modal fade" id="{{ modalId }}" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-scrollable modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title {{ isAr ? 'kh-rtl' : '' }}" {% if isAr %}style="font-family: 'Cairo', sans-serif;"{% endif %}>{{ a.title }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body {{ isAr ? 'kh-rtl kh-ar-font' : '' }}" style="white-space: pre-line;">
                                        {{ a.content }}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}

                {% if shown == 0 %}
                    <div class="text-muted">Aucun article.</div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body p-4">
                <div class="fw-semibold text-darken mb-3">Raccourcis</div>
                <div class="d-grid gap-2">
                    <a class="btn btn-primary" href="{{ path('app_profile') }}"><i class="fa-regular fa-user me-2"></i>Profil</a>
                    <a class="btn btn-outline-primary" href="{{ path('app_cv_manage') }}"><i class="fa-regular fa-file-lines me-2"></i>CV</a>
                    <a class="btn btn-light border" href="{{ path('app_user_offers') }}"><i class="fa-solid fa-briefcase me-2"></i>Offres</a>
                    <a class="btn btn-light border" href="#" onclick="return false;" title="Bientôt disponible"><i class="fa-regular fa-newspaper me-2"></i>Actualités</a>
                    <a class="btn btn-light border" href="#" onclick="return false;"><i class="fa-regular fa-flag me-2"></i>Réclamations</a>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body p-4">
                <div class="fw-semibold text-darken mb-2" style="font-family: 'Cairo', sans-serif;">رسالة اليوم</div>
                <div class="text-muted" style="font-family: 'Cairo', sans-serif;">ابدأ الآن مع «خدمني»: حسّن سيرتك الذاتية بخطوات بسيطة، وخلي فرص التدريب والعمل أقرب ليك كل يوم.</div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
