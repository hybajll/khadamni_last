{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="rounded-4 bg-cream shadow-sm p-4 mb-4">
        <h1 class="h4 mb-1 text-darken">Modifier mon profil</h1>
        <p class="text-muted mb-0">Vous pouvez modifier votre téléphone, votre mot de passe et votre photo.</p>
        <nav aria-label="breadcrumb" class="mt-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="{{ path('app_user_home') }}">Accueil</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_profile') }}">Mon profil</a></li>
                <li class="breadcrumb-item active" aria-current="page">Modifier</li>
            </ol>
        </nav>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body p-4">
                    {% if app.user and app.user.avatarPath %}
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <img
                                src="{{ asset(app.user.avatarPath) }}"
                                alt="Avatar"
                                class="rounded-circle border"
                                style="width: 72px; height: 72px; object-fit: cover;"
                            >
                            <div class="text-muted">
                                Photo actuelle. Vous pouvez la remplacer ci-dessous.
                            </div>
                        </div>
                    {% endif %}

                    {{ form_start(form) }}

                    <div class="row g-3">
                        <div class="col-12">
                            {{ form_row(form.avatarFile, {attr: {class: 'form-control'}}) }}
                        </div>
                    </div>

                    <div class="bg-light rounded-4 p-3 mt-3">
                        <div class="fw-semibold mb-2">Informations (non modifiables)</div>
                        <div class="row g-2">
                            <div class="col-md-4"><span class="text-muted">Nom :</span> <strong>{{ app.user.nom ?: '-' }}</strong></div>
                            <div class="col-md-4"><span class="text-muted">Prénom :</span> <strong>{{ app.user.prenom ?: '-' }}</strong></div>
                            <div class="col-md-4"><span class="text-muted">Email :</span> <strong>{{ app.user.email }}</strong></div>
                        </div>
                    </div>

                    <div class="mt-3">
                        {{ form_row(form.phone, {attr: {class: 'form-control'}}) }}
                    </div>

                    <div class="mt-3">
                        {{ form_row(form.plainPassword, {attr: {class: 'form-control'}}) }}
                        <div class="form-text">Laissez vide pour conserver le mot de passe actuel.</div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <a href="{{ path('app_profile') }}" class="btn btn-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary">Enregistrer</button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
