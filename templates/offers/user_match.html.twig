{% extends 'base.html.twig' %}

{% block title %}Matching Offres - Khadamni{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="rounded-4 bg-cream shadow-sm p-4 mb-4">
        <h1 class="h4 mb-1 text-darken">Matching (IA)</h1>
        <p class="text-muted mb-0">Compatibilité entre votre CV et les offres actives.</p>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a href="{{ path('app_user_offers') }}" class="btn btn-secondary">Retour aux offres</a>
        <a href="{{ path('app_cv_manage') }}" class="btn btn-light border">Mon CV</a>
    </div>

    <div class="card">
        <div class="card-body p-4">
            {% if results is empty %}
                <div class="text-muted">Aucun résultat.</div>
            {% else %}
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Offre</th>
                            <th style="width: 110px;">Score</th>
                            <th>Matching</th>
                            <th>Manquant</th>
                            <th>Pourquoi</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for row in results %}
                            <tr>
                                <td class="fw-semibold">{{ row.job_title }}</td>
                                <td>
                                    <span class="badge text-bg-{% if row.score >= 70 %}success{% elseif row.score >= 45 %}warning{% else %}secondary{% endif %}">
                                        {{ row.score }}%
                                    </span>
                                </td>
                                <td class="text-muted">
                                    {% if row.matching_skills is empty %}
                                        -
                                    {% else %}
                                        {{ row.matching_skills|slice(0, 6)|join(', ') }}
                                    {% endif %}
                                </td>
                                <td class="text-muted">
                                    {% if row.missing_skills is empty %}
                                        -
                                    {% else %}
                                        {{ row.missing_skills|slice(0, 6)|join(', ') }}
                                    {% endif %}
                                </td>
                                <td class="text-muted">{{ row.reason }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

