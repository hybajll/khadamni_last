{% extends 'base.html.twig' %}

{% block title %}{{ offer.title }} — Offre{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="bg-white rounded-4 p-4 p-md-5 shadow-sm">
                <div class="d-flex justify-content-between flex-wrap gap-2">
                    <div>
                        <h1 class="h3 fw-bold mb-2 text-darken">{{ offer.title }}</h1>
                        <div class="text-muted">
                            <strong>{{ offer.society.name }}</strong>
                            {% if offer.location %} • {{ offer.location }}{% endif %}
                            {% if offer.contractType %} • {{ offer.contractType }}{% endif %}
                            {% if offer.experienceLevel %} • {{ offer.experienceLevel }}{% endif %}
                        </div>
                    </div>
                    <div class="d-flex gap-2 align-items-start">
                        {% if is_granted('ROLE_USER') %}
                            <form method="post" action="{{ path('app_user_offers_apply', {id: offer.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('apply_offer_' ~ offer.id) }}">
                                <button type="submit" class="btn btn-outline-primary">Postuler</button>
                            </form>
                        {% else %}
                            <a class="btn btn-outline-primary" href="{{ path('app_login') }}">Postuler (connexion)</a>
                        {% endif %}
                        <a class="btn btn-primary" href="{{ path('society_login') }}">Publier une offre</a>
                    </div>
                </div>

                <hr class="my-4">

                <div class="text-darken" style="white-space: pre-line;">
                    {{ offer.description }}
                </div>
            </div>

            <div class="mt-3 text-center text-muted">
                Retour à l’accueil : <a href="{{ path('app_home') }}" class="text-orange text-decoration-none">خدمني</a>
            </div>
        </div>
    </div>
{% endblock %}
