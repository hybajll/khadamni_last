{% extends 'base.html.twig' %}

{% block title %}Offres - Khadamni{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="rounded-4 bg-cream shadow-sm p-4 mb-4">
        <h1 class="h4 mb-1 text-darken">Offres</h1>
        <p class="text-muted mb-0">Consultez les offres et lancez le matching avec votre CV.</p>
    </div>

    <div class="alert alert-light border">
        {% set remaining = 2 - (app.user.freeUsageCount ?? 0) %}
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <span class="fw-semibold">Actions gratuites restantes :</span>
                <span class="badge text-bg-light border">{{ remaining > 0 ? remaining : 0 }} / 2</span>
            </div>
            <a class="text-decoration-none text-orange fw-semibold" href="{{ path('app_subscription') }}">Abonnement</a>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a href="{{ path('app_user_offers_recommended') }}" class="btn btn-primary">
            <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Offres compatibles (CV)
        </a>
        <a href="{{ path('app_user_home') }}" class="btn btn-secondary">Retour</a>
    </div>

    <div class="card">
        <div class="card-body p-4">
            {% if offers is empty %}
                <div class="text-muted">Aucune offre active pour le moment.</div>
            {% else %}
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Domaine</th>
                            <th>Contrat</th>
                            <th>Lieu</th>
                            <th class="text-end">Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for offer in offers %}
                            <tr>
                                <td class="fw-semibold">{{ offer.title }}</td>
                                <td class="text-muted">{{ offer.domain ?: '-' }}</td>
                                <td class="text-muted">{{ offer.contractType }}</td>
                                <td class="text-muted">{{ offer.location ?: '-' }}</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-light border" href="{{ path('app_offer_public_show', {id: offer.id}) }}">
                                        Détails
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
