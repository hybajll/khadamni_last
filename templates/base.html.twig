<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Khadamni - Recrutement Intelligent{% endblock %}</title>
        
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        
        <style>
            :root {
                --primary-blue: #003366;
                --accent-orange: #FF8C00;
                --bg-light: #f8f9fa;
            }

            body {
                font-family: 'Poppins', sans-serif;
                background-color: var(--bg-light);
                color: #333;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* Navigation */
            .navbar {
                background-color: var(--primary-blue);
                border-bottom: 4px solid var(--accent-orange);
                padding: 1rem 0;
            }

            .navbar-brand {
                font-weight: 700;
                letter-spacing: 2px;
                text-transform: uppercase;
                font-size: 1.5rem;
            }

            .btn-home {
                color: white;
                border: 1px solid rgba(255, 255, 255, 0.4);
                border-radius: 8px;
                padding: 6px 15px;
                transition: all 0.3s;
                text-decoration: none;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .btn-home:hover {
                background-color: rgba(255, 255, 255, 0.1);
                border-color: var(--accent-orange);
                color: var(--accent-orange);
            }

            .main-content {
                flex: 1;
                padding: 40px 0;
            }

            footer {
                background-color: #ffffff;
                padding: 25px 0;
                border-top: 1px solid #dee2e6;
                color: #6c757d;
                font-size: 0.9rem;
            }
        </style>

        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-dark shadow-sm">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="navbar-brand" href="{{ path('app_candidature_new') }}">
                    <span style="color: var(--accent-orange)">KHADA</span>MNI
                </a>
                
                <a href="{{ path('app_candidature_new') }}" class="btn-home">
                    <i class="bi bi-house-door"></i>
                    ACCUEIL
                </a>
            </div>
        </nav>

        <main class="main-content">
            <div class="container">
                {# Flash Messages #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} alert-dismissible fade show shadow-sm mb-4" role="alert">
                            <i class="bi {{ label == 'danger' ? 'bi-exclamation-triangle' : 'bi-check-circle' }} me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </main>

        <footer class="mt-auto">
            <div class="container text-center">
                <p class="mb-1 fw-bold" style="color: var(--primary-blue)">KHADAMNI WEB</p>
                <p class="mb-0">© {{ "now"|date("Y") }} - Recrutement Intelligent</p>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>