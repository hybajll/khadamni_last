<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <title>{% block title %}Khadamni{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>●</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@600;700;800&display=swap" rel="stylesheet">

        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

        <style>
            :root {
                --kh-orange: #ff8c00;
                --kh-navy: #0a2340;
                --kh-cream: #fff8ed;
                --kh-text: #0f172a;
            }

            html, body {
                min-height: 100%;
                background: var(--kh-cream) !important;
            }

            body {
                color: var(--kh-text);
                font-family: 'Poppins', sans-serif;
            }

            .bg-cream {
                background: var(--kh-cream) !important;
            }

            .text-darken {
                color: var(--kh-text);
            }

            .text-orange {
                color: var(--kh-orange) !important;
            }

            .navbar {
                background: linear-gradient(135deg, var(--kh-navy) 0%, #102f52 100%) !important;
            }

            .navbar-brand {
                font-weight: 800;
                letter-spacing: 0.02em;
            }

            .nav-link {
                color: rgba(255, 255, 255, 0.9) !important;
            }

            .nav-link:hover {
                color: var(--kh-orange) !important;
            }

            .card {
                border: none;
                border-radius: 1rem;
                box-shadow: 0 1rem 2rem rgba(15, 47, 70, 0.10);
            }

            /* Feed-like articles (UserHome) */
            .kh-chip {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 10px 14px;
                border-radius: 999px;
                text-decoration: none;
                font-weight: 600;
                color: rgba(15, 23, 42, 0.75);
                background: rgba(255, 255, 255, 0.75);
                border: 1px solid rgba(15, 23, 42, 0.10);
            }

            .kh-chip:hover {
                border-color: rgba(255, 140, 0, 0.35);
                color: rgba(15, 23, 42, 0.9);
            }

            .kh-chip.active {
                background: rgba(255, 140, 0, 0.15);
                border-color: rgba(255, 140, 0, 0.45);
                color: rgba(15, 23, 42, 0.95);
            }

            .kh-feed-card {
                background: rgba(255, 255, 255, 0.85);
                border: 1px solid rgba(15, 23, 42, 0.08);
                border-radius: 1.25rem;
                overflow: hidden;
                box-shadow: 0 1rem 2rem rgba(15, 47, 70, 0.08);
            }

            .kh-feed-header {
                padding: 14px 18px;
            }

            .kh-feed-avatar {
                width: 42px;
                height: 42px;
                border-radius: 999px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
                letter-spacing: 0.04em;
                color: #ffffff;
                background: linear-gradient(135deg, var(--kh-navy), #274b78);
                border: 2px solid rgba(255, 255, 255, 0.55);
                box-shadow: 0 0.75rem 1.5rem rgba(10, 35, 64, 0.18);
            }

            .kh-feed-avatar.ar {
                font-family: 'Cairo', sans-serif;
                letter-spacing: 0;
            }

            .kh-feed-cover {
                position: relative;
                padding: 18px;
                background:
                    radial-gradient(1200px 380px at 0% 0%, rgba(255, 140, 0, 0.22), transparent 55%),
                    radial-gradient(900px 340px at 90% 30%, rgba(16, 47, 82, 0.22), transparent 60%),
                    linear-gradient(135deg, rgba(10, 35, 64, 0.92), rgba(16, 47, 82, 0.92));
                color: #ffffff;
            }

            .kh-feed-cover-inner {
                border-radius: 1rem;
                padding: 18px;
                background: rgba(255, 255, 255, 0.06);
                border: 1px solid rgba(255, 255, 255, 0.14);
                backdrop-filter: blur(6px);
            }

            .kh-feed-title {
                font-weight: 800;
                font-size: 1.05rem;
                line-height: 1.35;
            }

            .kh-feed-summary {
                margin-top: 10px;
                color: rgba(255, 255, 255, 0.82);
                line-height: 1.6;
            }

            .kh-feed-actions {
                display: flex;
                align-items: center;
                gap: 14px;
                padding: 12px 18px;
                border-bottom: 1px solid rgba(15, 23, 42, 0.06);
                background: rgba(255, 255, 255, 0.65);
            }

            .kh-action {
                color: rgba(15, 23, 42, 0.65);
                text-decoration: none;
            }

            .kh-action:hover {
                color: rgba(255, 140, 0, 0.95);
            }

            .kh-feed-body {
                padding: 16px 18px 18px 18px;
            }

            .kh-feed-text {
                color: rgba(15, 23, 42, 0.78);
                line-height: 1.75;
            }

            .kh-rtl {
                direction: rtl;
                text-align: right;
            }

            .kh-ar-font {
                font-family: 'Cairo', sans-serif;
            }

            /* Market news (UserHome) */
            .kh-news-row {
                display: grid;
                grid-auto-flow: column;
                grid-auto-columns: minmax(280px, 1fr);
                gap: 14px;
                overflow-x: auto;
                padding-bottom: 8px;
                scroll-snap-type: x mandatory;
                -webkit-overflow-scrolling: touch;
            }

            .kh-news-row::-webkit-scrollbar {
                height: 8px;
            }

            .kh-news-row::-webkit-scrollbar-thumb {
                background: rgba(15, 23, 42, 0.15);
                border-radius: 999px;
            }

            .kh-news-card {
                scroll-snap-align: start;
                border-radius: 1.25rem;
                padding: 16px;
                border: 1px solid rgba(15, 23, 42, 0.08);
                background:
                    radial-gradient(900px 260px at 0% 0%, rgba(255, 140, 0, 0.18), transparent 55%),
                    radial-gradient(700px 220px at 90% 30%, rgba(16, 47, 82, 0.16), transparent 60%),
                    rgba(255, 255, 255, 0.9);
                box-shadow: 0 1rem 2rem rgba(15, 47, 70, 0.08);
                min-height: 190px;
                display: flex;
                flex-direction: column;
                gap: 10px;
            }

            .kh-news-top {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 10px;
            }

            .kh-news-pill {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 6px 10px;
                border-radius: 999px;
                background: rgba(10, 35, 64, 0.08);
                border: 1px solid rgba(10, 35, 64, 0.10);
                color: rgba(15, 23, 42, 0.85);
                font-weight: 700;
                font-size: 0.78rem;
            }

            .kh-news-pill.light {
                background: rgba(255, 255, 255, 0.6);
            }

            .kh-news-title {
                font-weight: 800;
                color: rgba(15, 23, 42, 0.95);
                line-height: 1.35;
            }

            .kh-news-summary {
                color: rgba(15, 23, 42, 0.72);
                line-height: 1.65;
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .kh-news-bottom {
                margin-top: auto;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .kh-news-badge {
                font-size: 0.78rem;
                font-weight: 700;
                padding: 6px 10px;
                border-radius: 999px;
                color: rgba(10, 35, 64, 0.95);
                background: rgba(255, 140, 0, 0.16);
                border: 1px solid rgba(255, 140, 0, 0.28);
            }

            .btn-primary {
                background-color: var(--kh-orange);
                border-color: var(--kh-orange);
            }

            .btn-primary:hover {
                background-color: #e57a00;
                border-color: #e57a00;
            }

            .btn-outline-primary {
                color: var(--kh-orange);
                border-color: var(--kh-orange);
            }

            .btn-outline-primary:hover {
                background-color: var(--kh-orange);
                border-color: var(--kh-orange);
            }

            .hero-auth {
                min-height: calc(100vh - 90px);
            }

            .logo-khadamni {
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                font-family: 'Cairo', sans-serif;
                line-height: 1;
            }

            .logo-khadamni .logo-text {
                font-size: 1.35rem;
                font-weight: 800;
                color: var(--kh-orange);
            }

            .logo-khadamni small {
                font-size: 0.85rem;
                color: rgba(255, 255, 255, 0.85);
                margin-top: 0.15rem;
            }

            .nav-avatar {
                width: 34px;
                height: 34px;
                border-radius: 999px;
                object-fit: cover;
                border: 2px solid rgba(255, 255, 255, 0.35);
            }

            .nav-avatar-fallback {
                width: 34px;
                height: 34px;
                border-radius: 999px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
                color: #ffffff;
                background: rgba(255, 255, 255, 0.18);
                border: 2px solid rgba(255, 255, 255, 0.25);
                font-family: 'Poppins', sans-serif;
            }

            main {
                background: var(--kh-cream);
            }

            .sub-badge {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 6px 10px;
                border-radius: 999px;
                background: rgba(255, 255, 255, 0.14);
                border: 1px solid rgba(255, 255, 255, 0.18);
                color: rgba(255, 255, 255, 0.92);
                font-size: 0.85rem;
                font-weight: 600;
            }
            .sub-badge .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: #22c55e;
                box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25);
            }
            .sub-badge .dot.off {
                background: #f59e0b;
                box-shadow: 0 0 0 2px rgba(245, 158, 11, 0.25);
            }
        </style>

        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
            <div class="container">
                {# Lien Logo Dynamique #}
                <a class="navbar-brand" href="{% if app.user %}{% if 'ROLE_SOCIETY' in app.user.roles %}{{ path('society_home') }}{% elseif app.user.type == 'admin' %}{{ path('app_admin_dashboard') }}{% else %}{{ path('app_user_home') }}{% endif %}{% else %}{{ path('app_home') }}{% endif %}">
                    <div class="logo-khadamni">
                        <span class="logo-text">خدمني</span>
                        <small>خدمتك معانا مضمونة</small>
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        {% if app.user %}
                            {% set isSociety = 'ROLE_SOCIETY' in app.user.roles %}
                            {# MENU ENTREPRISE #}
                            {% if isSociety %}
                                <li class="nav-item"><a class="nav-link" href="{{ path('society_home') }}">Accueil</a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('society_offers_feed') }}">Offres</a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('society_offer_new') }}">Publier</a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('society_profile') }}">Profil</a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('society_subscription') }}">Abonnement</a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('app_user_reclamation_index') }}">Reclamation</a></li>
                                <li class="nav-item d-none d-lg-flex align-items-center ms-lg-2">
                                    {% set remaining = 1 - (app.user.freeUsageCount ?? 0) %}
                                    <a class="text-decoration-none" href="{{ path('society_subscription') }}">
                                        <span class="sub-badge">
                                            {% if app.user.subscriptionEndDate and app.user.subscriptionEndDate > date() %}
                                                <span class="dot"></span>Abonné
                                            {% else %}
                                                <span class="dot off"></span>Free: {{ remaining > 0 ? remaining : 0 }}/1
                                            {% endif %}
                                        </span>
                                    </a>
                                </li>
                            
                            {# MENU ADMIN #}
                            {% elseif app.user.type == 'admin' %}
                                <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_dashboard') }}">Admin Dashboard</a></li>
                            
                            {# MENU CANDIDAT #}
                            {% else %}
                                <li class="nav-item"><a class="nav-link" href="{{ path('app_user_home') }}">Accueil</a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('app_profile') }}">Profil</a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('app_cv_manage') }}">CV</a></li>
                                <li class="nav-item dropdown" id="khNotifNav">
                                    <a class="nav-link dropdown-toggle position-relative" href="#" id="notifDrop" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa-regular fa-bell"></i>
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="khNotifBadge">0</span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end p-0" style="width: 360px; max-width: 90vw;">
                                        <li class="px-3 py-2 border-bottom d-flex align-items-center justify-content-between">
                                            <span class="fw-bold">Notifications</span>
                                            <a class="small text-decoration-none" href="{{ path('app_notifications_index') }}">Tout voir</a>
                                        </li>
                                        <li>
                                            <div id="khNotifList" class="list-group list-group-flush" style="max-height: 340px; overflow:auto;">
                                                <div class="px-3 py-3 text-muted small">Chargement…</div>
                                            </div>
                                        </li>
                                    </ul>
                                </li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('app_user_reclamation_index') }}">Réclamations</a></li>
                                <li class="nav-item d-none d-lg-flex align-items-center ms-lg-2">
                                    {% set remaining = 2 - (app.user.freeUsageCount ?? 0) %}
                                    <a class="text-decoration-none" href="{{ path('app_subscription') }}">
                                        <span class="sub-badge">
                                            {% if app.user.subscriptionEndDate and app.user.subscriptionEndDate > date() %}
                                                <span class="dot"></span>Abonné
                                            {% else %}
                                                <span class="dot off"></span>Free: {{ remaining > 0 ? remaining : 0 }}/2
                                            {% endif %}
                                        </span>
                                    </a>
                                </li>
                            {% endif %}
                            <li class="nav-item"><a class="nav-link" href="{{ path(isSociety ? 'society_logout' : 'app_logout') }}">Déconnexion</a></li>
                            <li class="nav-item ms-lg-2 d-flex align-items-center">
                                <a class="nav-link py-1" href="{{ path(isSociety ? 'society_profile' : 'app_profile') }}" title="Mon profil">
                                    {% set avatarPath = attribute(app.user, 'avatarPath') is defined ? attribute(app.user, 'avatarPath') : null %}
                                    {% if avatarPath %}
                                        <img src="{{ asset(avatarPath) }}" alt="Avatar" class="nav-avatar">
                                    {% else %}
                                        {% set displayName = isSociety ? (app.user.name ?: app.user.email) : (app.user.prenom ?: app.user.email) %}
                                        <span class="nav-avatar-fallback">{{ displayName|first|upper }}</span>
                                    {% endif %}
                                </a>
                            </li>
                        {% else %}
                            {# MENU NON CONNECTÉ #}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="loginDrop" data-bs-toggle="dropdown">Connexion</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="{{ path('app_login') }}">Candidat</a></li>
                                    <li><a class="dropdown-item" href="{{ path('society_login') }}">Entreprise</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="regDrop" data-bs-toggle="dropdown">Inscription</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="{{ path('app_register') }}">Candidat</a></li>
                                    <li><a class="dropdown-item" href="{{ path('society_register') }}">Entreprise</a></li>
                                </ul>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <main class="py-5">
            {% block main_container_open %}<div class="container">{% endblock %}
                {% for label, messages in app.flashes %}
                    <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
                        {{ messages|first }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% block body %}{% endblock %}
            {% block main_container_close %}</div>{% endblock %}
        </main>

        <footer class="bg-white border-top py-3 text-center text-muted">
            <div class="container d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
                <div>© {{ "now"|date('Y') }} Khadamni</div>
                <a class="text-decoration-none text-orange fw-semibold" href="{{ path('app_home') }}">
                    <i class="fa-solid fa-arrow-left me-2"></i>Retour à l’accueil
                </a>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            (function () {
                const userIsLogged = {{ app.user ? 'true' : 'false' }};
                if (!userIsLogged) return;

                const userIsSociety = {{ app.user and ('ROLE_SOCIETY' in app.user.roles) ? 'true' : 'false' }};
                const userIsAdmin = {{ app.user and (app.user.type is defined and app.user.type == 'admin') ? 'true' : 'false' }};
                if (userIsSociety || userIsAdmin) return;

                const badge = document.getElementById('khNotifBadge');
                const list = document.getElementById('khNotifList');
                if (!badge || !list) return;

                const url = {{ path('app_notifications_api_summary')|json_encode|raw }};

                function esc(s) {
                    return String(s ?? '').replace(/[&<>"']/g, m => ({
                        '&': '&amp;',
                        '<': '&lt;',
                        '>': '&gt;',
                        '"': '&quot;',
                        "'": '&#39;',
                    })[m]);
                }

                function render(items) {
                    if (!items || items.length === 0) {
                        list.innerHTML = '<div class="px-3 py-3 text-muted small">Aucune notification.</div>';
                        return;
                    }

                    const fallbackLink = {{ path('app_notifications_index')|json_encode|raw }};

                    list.innerHTML = items.map(n => {
                        const link = n.link ? esc(n.link) : fallbackLink;
                        const icon = n.icon ? `<i class="bi ${esc(n.icon)} me-2"></i>` : '<i class="fa-regular fa-bell me-2"></i>';
                        const title = esc(n.title);
                        const msg = esc(n.message);
                        const time = esc(n.createdAt);
                        const strong = n.isRead ? '' : 'fw-semibold';
                        return `
                            <a href="${link}" class="list-group-item list-group-item-action">
                                <div class="d-flex gap-2">
                                    <div class="pt-1">${icon}</div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div class="${strong}">${title}</div>
                                            <div class="text-muted small">${time}</div>
                                        </div>
                                        <div class="text-muted small">${msg}</div>
                                    </div>
                                </div>
                            </a>
                        `;
                    }).join('');
                }

                async function refresh() {
                    try {
                        const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
                        if (!res.ok) throw new Error('HTTP ' + res.status);
                        const data = await res.json();

                        const count = Number(data.unreadCount ?? 0);
                        if (count > 0) {
                            badge.textContent = String(count);
                            badge.classList.remove('d-none');
                        } else {
                            badge.classList.add('d-none');
                        }

                        render(data.items ?? []);
                    } catch (e) {
                        list.innerHTML = '<div class="px-3 py-3 text-muted small">Notifications indisponibles.</div>';
                    }
                }

                refresh();
                setInterval(refresh, 30000);
            })();
        </script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
