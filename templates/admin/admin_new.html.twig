{% extends 'base.html.twig' %}

{% block title %}Admin - New Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h1 class="h4 mb-1 text-darken">Ajouter un administrateur</h1>
            <div class="text-muted">Création manuelle d’un admin.</div>
        </div>
        <a href="{{ path('app_admin_admins') }}" class="btn btn-secondary">Retour</a>
    </div>

    <div class="card">
        <div class="card-body p-4">
            {% if form.vars.submitted and not form.vars.valid %}
                <div class="alert alert-danger mb-3">
                    Le formulaire contient des erreurs. Vérifiez les champs ci-dessous.
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            {{ form_start(form, { attr: { novalidate: 'novalidate', 'data-turbo': 'false' } }) }}

            <div class="row g-3">
                <div class="col-md-6">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {attr: {class: 'form-control'}}) }}
                    <div class="text-danger small mt-1">{{ form_errors(form.nom) }}</div>
                </div>
                <div class="col-md-6">
                    {{ form_label(form.prenom) }}
                    {{ form_widget(form.prenom, {attr: {class: 'form-control'}}) }}
                    <div class="text-danger small mt-1">{{ form_errors(form.prenom) }}</div>
                </div>
            </div>

            <div class="mt-3">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {attr: {class: 'form-control'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.email) }}</div>
            </div>

            <div class="mt-3">
                {{ form_label(form.adminRole) }}
                {{ form_widget(form.adminRole, {attr: {class: 'form-select'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.adminRole) }}</div>
            </div>

            <div class="mt-3">
                {{ form_label(form.plainPassword) }}
                {{ form_widget(form.plainPassword, {attr: {class: 'form-control'}}) }}
                <div class="form-text">{{ form_help(form.plainPassword) }}</div>
                <div class="text-danger small mt-1">{{ form_errors(form.plainPassword) }}</div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <a href="{{ path('app_admin_admins') }}" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">Créer</button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
