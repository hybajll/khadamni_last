{% extends 'base.html.twig' %}

{% block title %}Admin - Sociétés{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
        <div>
            <h1 class="h4 mb-1 text-darken">Sociétés</h1>
            <div class="text-muted">Espace modérateur (liste des entreprises). Actions réservées au superadmin.</div>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <form method="get" class="d-flex gap-2" action="{{ path('app_admin_societies') }}">
                <input type="search" name="q" value="{{ q|default('') }}" class="form-control" placeholder="Rechercher (nom, email)">
                <button class="btn btn-primary" type="submit">Rechercher</button>
                {% if q|default('') %}
                    <a class="btn btn-light border" href="{{ path('app_admin_societies') }}">Reset</a>
                {% endif %}
            </form>
            <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">Retour</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Domaine</th>
                            <th>Active</th>
                            <th>Créée</th>
                            {% if is_granted('ROLE_SUPERADMIN') %}<th class="text-end">Actions</th>{% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for s in societies %}
                            <tr>
                                <td>{{ s.id }}</td>
                                <td class="fw-semibold">{{ s.name }}</td>
                                <td class="text-muted">{{ s.email }}</td>
                                <td class="text-muted">{{ s.domain ?: '-' }}</td>
                                <td>
                                    {% if s.active %}
                                        <span class="badge text-bg-success">Active</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary">Inactive</span>
                                    {% endif %}
                                </td>
                                <td class="text-muted">{{ s.createdAt ? s.createdAt|date('d/m/Y') : '-' }}</td>
                                {% if is_granted('ROLE_SUPERADMIN') %}
                                    <td class="text-end">
                                        <form method="post" action="{{ path('app_admin_society_toggle_active', {id: s.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_society_' ~ s.id) }}">
                                            <button class="btn btn-sm btn-outline-primary" type="submit">
                                                {{ s.active ? 'Désactiver' : 'Activer' }}
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('app_admin_society_delete', {id: s.id}) }}" onsubmit="return confirm('Supprimer cette société ?');" class="d-inline ms-1">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_society_' ~ s.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                                        </form>
                                    </td>
                                {% endif %}
                            </tr>
                        {% else %}
                            <tr><td colspan="{{ is_granted('ROLE_SUPERADMIN') ? 7 : 6 }}" class="text-center text-muted py-4">Aucune société.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

