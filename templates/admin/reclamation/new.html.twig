{# templates/admin/reclamation/new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Khadamni - Nouvelle Réclamation{% endblock %}

{% block body %}
<style>
    .form-card { border-radius: 12px; overflow: hidden; background: #fff; }
    .form-header { background-color: #2c3e50; color: white; padding: 1.5rem; }
    .btn-save { background-color: #27ae60; color: white; transition: 0.3s; }
    .btn-save:hover { background-color: #2ecc71; transform: translateY(-1px); }
</style>

<div class="container mt-5" style="max-width: 800px;">
    <div class="form-card shadow-lg">
        {# Header avec retour sécurisé #}
        <div class="form-header d-flex align-items-center">
            <a href="{{ path('app_admin_reclamation_index') }}" class="btn btn-outline-light btn-sm rounded-circle me-3" title="Retour">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h4 class="mb-0 fw-bold">Nouvelle réclamation</h4>
        </div>

        <div class="p-4">
            {{ form_start(form) }}
                {# Sujet #}
                <div class="mb-3">
                    <label class="fw-bold mb-1">Sujet :</label>
                    {{ form_widget(form.sujet, {'attr': {'class': 'form-control border-secondary-subtle', 'placeholder': 'Ex: Problème d\'accès au profil'}}) }}
                    <div class="text-danger small">{{ form_errors(form.sujet) }}</div>
                </div>

                {# Description #}
                <div class="mb-3">
                    <label class="fw-bold mb-1">Description détaillée :</label>
                    {{ form_widget(form.description, {'attr': {'class': 'form-control border-secondary-subtle', 'rows': '5', 'placeholder': 'Expliquez-nous votre problème ici...'}}) }}
                    <div class="text-danger small">{{ form_errors(form.description) }}</div>
                </div>

                {# Type #}
                <div class="row">
                    <div class="col-md-6">
                        <label class="fw-bold mb-1">Type de réclamation :</label>
                        {{ form_widget(form.type, {'attr': {'class': 'form-select border-secondary-subtle'}}) }}
                        <div class="text-danger small">{{ form_errors(form.type) }}</div>
                    </div>
                </div>

                <hr class="my-4 opacity-25">

                {# Actions #}
                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_admin_reclamation_index') }}" class="btn btn-light border px-4">Annuler</a>
                    
                    <button type="submit" class="btn btn-save px-5 fw-bold shadow-sm">
                        <i class="fas fa-paper-plane me-2"></i> Envoyer la réclamation
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}