{% extends 'base.html.twig' %}

{% block title %}Modifier la Réclamation #{{ reclamation.idReclamation }}{% endblock %}

{% block body %}
<style>
    .form-card { border-radius: 12px; overflow: hidden; background: #fff; }
    .form-header { background-color: #2c3e50; color: white; padding: 1.2rem; }
    .btn-update { background-color: #2980b9; color: white; transition: 0.3s; fw-bold; }
    .btn-update:hover { background-color: #3498db; transform: translateY(-1px); color: white; }
</style>

<div class="container mt-5" style="max-width: 700px;">
    <div class="form-card shadow-lg border-0">
        {# Header #}
        <div class="form-header d-flex align-items-center">
            <a href="{{ path('app_admin_reclamation_index') }}" class="btn btn-outline-light btn-sm rounded-circle me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h5 class="mb-0 fw-bold">Modifier la réclamation #{{ reclamation.idReclamation }}</h5>
        </div>

        <div class="p-4">
            {{ form_start(form) }}
                <div class="mb-3">
                    <label class="fw-bold mb-1 small text-uppercase text-muted">Sujet</label>
                    {{ form_widget(form.sujet, {'attr': {'class': 'form-control border-secondary-subtle'}}) }}
                    <div class="text-danger small">{{ form_errors(form.sujet) }}</div>
                </div>

                <div class="mb-3">
                    <label class="fw-bold mb-1 small text-uppercase text-muted">Description</label>
                    {{ form_widget(form.description, {'attr': {'class': 'form-control border-secondary-subtle', 'rows': '6'}}) }}
                    <div class="text-danger small">{{ form_errors(form.description) }}</div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="fw-bold mb-1 small text-uppercase text-muted">Type de réclamation</label>
                        {{ form_widget(form.type, {'attr': {'class': 'form-select border-secondary-subtle'}}) }}
                        <div class="text-danger small">{{ form_errors(form.type) }}</div>
                    </div>
                    {# Le statut peut aussi être modifié ici si tu le souhaites #}
                    <div class="col-md-6">
                        <label class="fw-bold mb-1 small text-uppercase text-muted">Statut Actuel</label>
                        <div class="form-control bg-light border-0">
                            {{ reclamation.statut.getLabel() }}
                        </div>
                    </div>
                </div>

                <hr class="my-4 opacity-25">

                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_admin_reclamation_index') }}" class="btn btn-light border px-4 fw-bold">Annuler</a>
                    <button type="submit" class="btn btn-update px-5 shadow-sm">
                        <i class="fas fa-save me-2"></i> Enregistrer les modifications
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}