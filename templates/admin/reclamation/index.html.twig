{% extends 'base.html.twig' %}

{% block title %}Gestion des Réclamations{% endblock %}

{% block body %}
<style>
    /* Optimisation de la densité visuelle */
    .fs-7 { font-size: 0.82rem !important; }
    .table th { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; border-top: none; }
    .table td { font-size: 0.85rem; padding: 8px 5px !important; vertical-align: middle; }
    
    /* Badges et Boutons compacts */
    .badge-stat { font-size: 0.7rem !important; padding: 4px 10px; border-radius: 12px; }
    .btn-action { font-size: 0.75rem; font-weight: bold; padding: 3px 10px; display: inline-flex; align-items: center; gap: 5px; min-width: 90px; justify-content: center; }
    
    /* Style du sélecteur de statut */
    .select-statut { font-size: 0.75rem !important; height: 28px; width: 125px; border-radius: 4px; cursor: pointer; }

    /* Couleurs personnalisées pour les boutons */
    .btn-edit { background-color: #f39c12; color: white; border: none; }
    .btn-edit:hover { background-color: #e67e22; color: white; }
</style>

<div class="container-fluid p-0">
    {# Header Sombre Compact #}
    <div class="d-flex align-items-center justify-content-between px-3 py-2 bg-dark text-white shadow-sm">
        <h6 class="mb-0 fw-bold"><i class="fas fa-list-alt me-2 text-warning"></i>Gestion des Réclamations</h6>
        <a href="{{ path('app_reclamation_new') }}" class="btn btn-success btn-sm fw-bold px-3">
            <i class="fas fa-plus"></i> Nouvelle reclamation
        </a>
    </div>

    {# Bandeau de Statistiques Jaune (Style JavaFX) 
    <div class="d-flex justify-content-around align-items-center py-2 border-bottom shadow-sm" style="background-color: #f1c40f;">
        <span class="badge badge-stat bg-dark">Total: {{ stats.total }}</span>
        <span class="badge badge-stat bg-secondary">En Attente: {{ stats.en_attente }}</span>
        <span class="badge badge-stat bg-primary">En Cours: {{ stats.en_cours }}</span>
        <span class="badge badge-stat bg-success">Résolues: {{ stats.resolue }}</span>
    </div>
    #}
    <div class="p-2">
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Sujet & Utilisateur</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for rec in reclamations %}
                        <tr>
                            <td class="ps-3 fw-bold text-primary">#{{ rec.idReclamation }}</td>
                            <td>
                                <div class="fw-bold text-dark text-truncate" style="max-width: 180px;" title="{{ rec.sujet }}">
                                    {{ rec.sujet }}
                                </div>
                                <div class="text-muted fs-7">
                                    Client: {{ rec.user.nom|default('Inconnu') }}
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">
                                    {{ rec.typeLabel|default('Général') }}
                                </span>
                            </td>
                            <td>
                                <form action="{{ path('app_admin_reclamation_set_statut', {'id': rec.idReclamation, 'page': currentPage}) }}" method="post">
                                    <select name="statut" onchange="this.form.submit()" 
                                            class="form-select form-select-sm select-statut border-0 text-white fw-bold shadow-sm bg-{{ rec.statutBadgeClass|default('secondary') }}">
                                        {% for statut in statuts_disponibles %}
                                            <option value="{{ statut.value }}" {{ (rec.statut.value == statut.value) ? 'selected' : '' }}>
                                                {{ statut.getLabel() }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </form>
                            </td>
                            <td class="text-muted fs-7">
                                <i class="far fa-clock me-1"></i>{{ rec.dateCreation|date('d/m H:i') }}
                            </td>
                            <td style="width: 310px;">
                                <div class="d-flex gap-2 justify-content-center">
                                    {# BOUTON MODIFIER (AJOUTÉ) #}
                                    <a href="{{ path('app_admin_reclamation_edit', {'id': rec.idReclamation}) }}" 
                                       class="btn btn-edit btn-action shadow-sm">
                                        <i class="fas fa-edit"></i> Modifier
                                    </a>

                                    {# BOUTON REPONDRE #}
                                    <a href="{{ path('app_admin_reclamation_chat', {'id': rec.idReclamation}) }}" 
                                       class="btn btn-info btn-action text-white shadow-sm">
                                        <i class="fas fa-reply"></i> Répondre
                                    </a>

                                    {# BOUTON SUPPRIMER #}
                                    <form method="post" action="{{ path('app_admin_reclamation_delete', {'id': rec.idReclamation, 'page': currentPage}) }}" 
                                          onsubmit="return confirm('Confirmer la suppression ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ rec.idReclamation) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-action shadow-sm">
                                            <i class="fas fa-trash"></i> Supprimer
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Aucune réclamation trouvée.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Footer avec Pagination Dynamique #}
            <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center py-2">
                <div class="text-muted fs-7">
                    Affichage de <b>{{ reclamations|length }}</b> sur {{ stats.total }}
                </div>
                
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('app_admin_reclamation_index', {page: currentPage - 1}) }}">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        {% for i in 1..totalPages %}
                            {% if totalPages > 0 %}
                            <li class="page-item {{ i == currentPage ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('app_admin_reclamation_index', {page: i}) }}">{{ i }}</a>
                            </li>
                            {% endif %}
                        {% endfor %}

                        <li class="page-item {{ currentPage == totalPages or totalPages == 0 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('app_admin_reclamation_index', {page: currentPage + 1}) }}">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<script>
    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(el => el.remove());
    }, 3000);
</script>
{% endblock %}