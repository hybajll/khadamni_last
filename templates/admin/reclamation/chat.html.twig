{% extends 'base.html.twig' %}

{% block body %}
<style>
    body { background-color: #828284; }
    .chat-card { width: 80%; max-width: 600px; margin: auto; background: #b7c3cf; border-radius: 15px; overflow: hidden; shadow: 0 4px 15px rgba(0,0,0,0.1); }
    .chat-box { height: 400px; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 15px; background: #fdfdfd; }
    .bubble { max-width: 80%; padding: 12px 16px; border-radius: 20px; font-size: 12px; position: relative; }
    .msg-admin { align-self: flex-end; background-color: #007bff; color: white; border-bottom-right-radius: 2px; }
    .msg-ai { align-self: flex-start; background-color: #f1f3f5; color: #333; border-bottom-left-radius: 2px; border-left: 4px solid #f1c54b; }
    .label { font-size: 10px; font-weight: bold; margin-bottom: 4px; text-transform: uppercase; display: block; }
</style>

<div class="py-5">
    <div class="chat-card">
        <div class="p-3 bg-dark text-white d-flex justify-content-between">
            <span>Chat #{{ reclamation.idReclamation }} - {{ reclamation.sujet }}</span>
            <a href="{{ path('app_admin_reclamations_index') }}" class="text-white text-decoration-none">Retour</a>
        </div>

        <div class="chat-box" id="chatContainer">
            {# Message original du client #}
            <div class="p-3 bg-light rounded mb-2" style="font-size: 13px; border-left: 4px solid #007bff;">
                <strong>Client :</strong> {{ reclamation.description }}
            </div>

            {% for msg in messages %}
                {% set isAi = msg.auteur is null %}
                <div class="{{ not isAi ? 'text-end' : 'text-start' }}">
                    <span class="label {{ not isAi ? 'text-primary' : 'text-muted' }}">
                        {{ isAi ? 'Assistant IA' : 'Support Admin' }}
                    </span>
                    <div class="bubble {{ not isAi ? 'msg-admin' : 'msg-ai' }}">
                        {{ msg.message|nl2br }}
                    </div>
                    <small class="text-muted" style="font-size: 10px;">{{ msg.dateReponse|date('H:i') }}</small>
                </div>
            {% endfor %}
        </div>

        <div class="p-3 border-top">
            <form method="post" class="d-flex gap-2">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_reply' ~ reclamation.idReclamation) }}">
                <input type="text" name="message" class="form-control rounded-pill" placeholder="Votre message..." required>
                <button type="submit" class="btn btn-primary rounded-circle"><i class="fas fa-paper-plane"></i></button>
            </form>
        </div>
    </div>
</div>

<script>
    const box = document.getElementById('chatContainer');
    box.scrollTop = box.scrollHeight;
</script>
{% endblock %}