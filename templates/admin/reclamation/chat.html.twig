{% extends 'base.html.twig' %}

{% block title %}Support Khadamni - Chat #{{ reclamation.idReclamation }}{% endblock %}

{% block body %}
<style>
    /* Arrière-plan de la page pour faire ressortir la carte */
    body {
        background-color: #b2bdce;
    }

    /* Conteneur principal centré */
    .chat-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh; /* Centre verticalement sur l'écran */
        padding: 20px;
    }

    /* La carte de chat */
    .chat-card {
        width: 100%;
        max-width: 700px; /* Largeur optimale pour la lecture */
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        overflow: hidden;
        border: none;
    }

    /* Zone des messages */
    .chat-box { 
        height: 450px; 
        overflow-y: auto; 
        background-color: #fdf6e3; /* Teinte crème pour le confort visuel */
        padding: 25px; 
        display: flex;
        flex-direction: column;
        scroll-behavior: smooth;
    }

    .message-wrapper { margin-bottom: 18px; display: flex; flex-direction: column; }
    
    .bubble { 
        max-width: 80%; 
        padding: 12px 18px; 
        border-radius: 18px; 
        font-size: 14.5px; 
        line-height: 1.5;
        position: relative;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
    
    /* Style Admin (Droite - Bleu) */
    .msg-admin { 
        align-self: flex-end; 
        background-color: #0084ff; 
        color: white; 
        border-bottom-right-radius: 4px; 
    }
    
    /* Style Client (Gauche - Gris) */
    .msg-client { 
        align-self: flex-start; 
        background-color: #ffffff; 
        color: #1c1e21; 
        border: 1px solid #e4e6eb;
        border-bottom-left-radius: 4px; 
    }
    
    .msg-date { font-size: 11px; color: #65676b; margin-bottom: 4px; }
    .admin-date { align-self: flex-end; }

    /* Custom Scrollbar pour un look moderne */
    .chat-box::-webkit-scrollbar { width: 6px; }
    .chat-box::-webkit-scrollbar-track { background: transparent; }
    .chat-box::-webkit-scrollbar-thumb { background: #ced4da; border-radius: 10px; }
</style>

<div class="chat-wrapper">
    <div class="chat-card animate__animated animate__fadeIn">
        
        <div class="card-header bg-white border-bottom py-3 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                        <i class="fas fa-user"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold text-dark">{{ reclamation.user.prenom }} {{ reclamation.user.nom }}</h6>
                        <span class="badge bg-soft-primary text-primary small" style="background-color: #e7f3ff; font-size: 0.75rem;">
                            id du client : #{{ reclamation.idReclamation }}
                        </span>
                    </div>
                </div>
                <a href="{{ path('app_admin_reclamation_index') }}" class="btn btn-light btn-sm rounded-pill px-3 border">
                    <i class="fas fa-times me-1"></i> Quitter
                </a>
            </div>
        </div>

        <div class="chat-box" id="chatContainer">
            <div class="message-wrapper">
                <span class="msg-date">Ouverture de la reclamation {{ reclamation.dateCreation|date('d/m H:i') }}</span>
                <div class="bubble msg-client">
                    <small class="fw-bold text-primary text-uppercase" style="font-size: 0.65rem;">Sujet : {{ reclamation.sujet }}</small><br>
                    {{ reclamation.description }}
                </div>
            </div>

            <div class="text-center my-3">
                <small class="text-muted bg-white px-2 py-1 rounded shadow-sm" style="font-size: 10px;"></small>
            </div>

            {% for msg in messages %}
                {% set isAdmin = msg.isAuteurAdmin %}
                <div class="message-wrapper">
                    <span class="msg-date {{ isAdmin ? 'admin-date' : '' }}">
                        {{ isAdmin ? 'Vous' : reclamation.user.prenom }} • {{ msg.dateReponse|date('H:i') }}
                    </span>
                    <div class="bubble {{ isAdmin ? 'msg-admin' : 'msg-client' }}">
                        {{ msg.message }}
                    </div>
                </div>
            {% else %}
                {% endfor %}
        </div>

        <div class="card-footer bg-white py-3 px-4 border-top">
            <form method="post" class="d-flex align-items-center gap-2">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_reply' ~ reclamation.idReclamation) }}">
                
                <div class="input-group">
                    <input type="text" name="message" class="form-control border-0 bg-light rounded-pill ps-4 py-2" 
                           placeholder="Écrivez votre message..." required autocomplete="off">
                    <button type="submit" class="btn btn-primary rounded-circle ms-2 shadow-sm d-flex align-items-center justify-content-center" 
                            style="width: 42px; height: 42px;">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function scrollToBottom() {
        const container = document.getElementById('chatContainer');
        container.scrollTop = container.scrollHeight;
    }
    window.onload = scrollToBottom;
</script>
{% endblock %}