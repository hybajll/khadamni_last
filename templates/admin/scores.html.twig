{% extends 'base.html.twig' %}

{% block title %}Candidatures - {{ offre.Title }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Offres</a></li>
                <li class="breadcrumb-item active" aria-current="page">Candidatures</li>
            </ol>
        </nav>
        
        <div class="d-flex justify-content-between align-items-end">
            <div>
                <h2 class="fw-bold mb-0" style="color: var(--primary-blue);">
                    Postulants pour : <span style="color: var(--accent-orange);">{{ offre.Title }}</span>
                </h2>
                <p class="text-muted mb-0">Analyse des profils reçus pour cette offre spécifique.</p>
            </div>
            <div class="text-end">
                <span class="badge rounded-pill bg-dark px-3 py-2">
                    {{ candidatures|length }} Candidat(s)
                </span>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold">Email du Candidat</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Score de Compatibilité</th>
                        <th class="pe-4 py-3 text-uppercase small fw-bold text-end">Documents</th>
                    </tr>
                </thead>
                <tbody>
                    {% for candidature in candidatures %}
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; font-weight: 600;">
                                        {{ candidature.email|first|upper }}
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">{{ candidature.email }}</div>
                                        <small class="text-muted text-uppercase" style="font-size: 0.75rem;">ID Candidature: #{{ candidature.id }}</small>
                                    </div>
                                </div>
                            </td>
                            <td style="width: 300px;">
                                {% set score = 0 %}
                                {% if candidature.recommendation %}
                                    {% set score = candidature.recommendation.score * 100 %}
                                {% endif %}
                                
                                <div class="d-flex align-items-center gap-3">
                                    <div class="progress flex-grow-1" style="height: 10px; border-radius: 5px; background-color: #e9ecef;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated 
                                            {% if score >= 80 %}bg-success{% elseif score >= 50 %}bg-warning{% else %}bg-danger{% endif %}" 
                                            role="progressbar" 
                                            style="width: {{ score }}%" 
                                            aria-valuenow="{{ score }}" 
                                            aria-valuemin="0" 
                                            aria-valuemax="100">
                                        </div>
                                    </div>
                                    <span class="fw-bold fs-5 {{ score >= 80 ? 'text-success' : (score >= 50 ? 'text-warning' : 'text-danger') }}">
                                        {{ score|round(0) }}%
                                    </span>
                                </div>
                            </td>
                            <td class="pe-4 text-end">
                                {% if candidature.cvPath %}
                                    <a href="{{ asset('uploads/cvs/' ~ candidature.cvPath) }}" 
                                       target="_blank" 
                                       class="btn btn-outline-dark btn-sm rounded-pill px-4 transition-all">
                                        <i class="bi bi-file-pdf-fill text-danger me-1"></i> Consulter CV
                                    </a>
                                {% else %}
                                    <span class="badge bg-light text-secondary">Aucun CV joint</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-person-x text-muted" style="font-size: 3rem;"></i>
                                    <p class="mt-3 text-muted">Aucune candidature n'a encore été déposée pour cette offre.</p>
                                    <a href="#" class="btn btn-sm btn-link">Actualiser la liste</a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-4 text-center">
        <p class="small text-muted">
            <i class="bi bi-info-circle me-1"></i> 
            Les scores sont générés automatiquement par l'IA de Khadamni en comparant le CV avec les exigences du poste.
        </p>
    </div>
</div>

<style>
    .transition-all:hover {
        background-color: var(--primary-blue) !important;
        color: white !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    .progress-bar {
        transition: width 1s ease-in-out;
    }
</style>
{% endblock %}