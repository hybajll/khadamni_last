{% extends 'base.html.twig' %}

{% block title %}Admin - CVs{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h1 class="h4 mb-1 text-darken">CVs</h1>
            <div class="text-muted">Liste de tous les CV.</div>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <form method="get" class="d-flex gap-2" action="{{ path('app_admin_cvs') }}">
                <input
                    type="search"
                    name="q"
                    value="{{ q|default('') }}"
                    class="form-control"
                    placeholder="Rechercher (titre, email)"
                >
                <button class="btn btn-primary" type="submit">Rechercher</button>
                {% if q|default('') %}
                    <a class="btn btn-light border" href="{{ path('app_admin_cvs') }}">Reset</a>
                {% endif %}
            </form>
            <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">Retour</a>
        </div>
    </div>

    <div class="accordion" id="cvsAccordion">
        {% for cv in cvs %}
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading{{ cv.id }}">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ cv.id }}" aria-expanded="false" aria-controls="collapse{{ cv.id }}">
                        #{{ cv.id }} — {{ cv.titre }} — {{ cv.user.email }}
                    </button>
                </h2>
                <div id="collapse{{ cv.id }}" class="accordion-collapse collapse" aria-labelledby="heading{{ cv.id }}" data-bs-parent="#cvsAccordion">
                    <div class="accordion-body">
                        {% if cv.pdfPath %}
                            <div class="mb-3">
                                <a class="btn btn-sm btn-light border" href="{{ asset(cv.pdfPath) }}" target="_blank" rel="noopener">
                                    Télécharger PDF importé
                                </a>
                            </div>
                        {% endif %}

                        <div class="row g-3">
                            <div class="col-lg-12">
                                <div class="fw-semibold mb-2">Dernière version</div>
                                <div class="bg-white border rounded-3 p-3" style="white-space: pre-wrap;">{{ cv.contenuOriginal }}</div>
                            </div>
                        </div>

                        {% if cv.conseilsAi %}
                            <div class="mt-3">
                                <div class="fw-semibold mb-2">Conseils (séparés du CV)</div>
                                <div class="bg-white border rounded-3 p-3" style="white-space: pre-wrap;">{{ cv.conseilsAi }}</div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-muted">Aucun CV.</div>
        {% endfor %}
    </div>
</div>
{% endblock %}

