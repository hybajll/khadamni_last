{% extends 'base.html.twig' %}

{% block title %}Inscription - Khadamni{% endblock %}

{% block body %}
<div class="hero-auth d-flex align-items-center justify-content-center bg-cream py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-darken mb-2">Créer un compte</h2>
                            <p class="text-muted mb-0">Renseignez vos informations pour créer votre compte.</p>
                        </div>

                        {% if formAjout.vars.submitted and not formAjout.vars.valid %}
                            <div class="alert alert-danger">Le formulaire contient des erreurs. Vérifiez les champs ci-dessous.</div>
                        {% endif %}

                        {{ form_start(formAjout, {'attr': {'novalidate': 'novalidate', 'data-turbo': 'false'}}) }}
                            <div class="mt-2">
                                {{ form_label(formAjout.avatarFile) }}
                                {{ form_widget(formAjout.avatarFile, {'attr': {'class': 'form-control'}}) }}
                                <div class="form-text">Formats acceptés: JPG, PNG, WEBP (max 2 Mo).</div>
                                <div class="text-danger mt-1 small">{{ form_errors(formAjout.avatarFile) }}</div>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    {{ form_label(formAjout.nom) }}
                                    {{ form_widget(formAjout.nom, {'attr': {'class': 'form-control'}}) }}
                                    <div class="text-danger mt-1 small">{{ form_errors(formAjout.nom) }}</div>
                                </div>
                                <div class="col-md-6">
                                    {{ form_label(formAjout.prenom) }}
                                    {{ form_widget(formAjout.prenom, {'attr': {'class': 'form-control'}}) }}
                                    <div class="text-danger mt-1 small">{{ form_errors(formAjout.prenom) }}</div>
                                </div>
                            </div>

                            <div class="mt-3">
                                {{ form_label(formAjout.email) }}
                                {{ form_widget(formAjout.email, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger mt-1 small">{{ form_errors(formAjout.email) }}</div>
                            </div>

                            <div class="mt-3">
                                {{ form_label(formAjout.password) }}
                                {{ form_widget(formAjout.password, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger mt-1 small">{{ form_errors(formAjout.password) }}</div>
                            </div>

                            <div class="mt-3">
                                {{ form_label(formAjout.type) }}
                                {{ form_widget(formAjout.type, {'attr': {'class': 'form-select'}}) }}
                                <div class="text-danger mt-1 small">{{ form_errors(formAjout.type) }}</div>
                            </div>

                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">S'inscrire</button>
                            </div>
                        {{ form_end(formAjout) }}

                        <div class="text-center mt-4">
                            <p class="mb-0">Vous avez déjà un compte ? <a href="{{ path('app_login') }}" class="text-orange">Connexion</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
